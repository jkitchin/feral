% ============================================================
% Dense Kernel: Pivot Theory (Bunch-Kaufman)
% ============================================================

@article{bunch1977stable,
  author    = {Bunch, James R. and Kaufman, Linda},
  title     = {Some Stable Methods for Calculating Inertia and Solving Symmetric
               Linear Systems},
  journal   = {Mathematics of Computation},
  year      = {1977},
  volume    = {31},
  number    = {137},
  pages     = {163--179},
  doi       = {10.1090/S0025-5718-1977-0428694-0},
  url       = {https://doi.org/10.1090/S0025-5718-1977-0428694-0},
  note      = {THE pivot paper. Theorem 3 gives the BK algorithm; Section 4 establishes
               alpha = (1+sqrt(17))/8. Proves 1x1 and 2x2 blocks are necessary and
               sufficient. Read Sections 2-4 before implementing.}
}

@article{bunch1971direct,
  author    = {Bunch, J. R. and Parlett, B. N.},
  title     = {Direct Methods for Solving Symmetric Indefinite Systems of Linear Equations},
  journal   = {{SIAM} Journal on Numerical Analysis},
  year      = {1971},
  volume    = {8},
  number    = {4},
  pages     = {639--655},
  doi       = {10.1137/0708060},
  url       = {https://doi.org/10.1137/0708060},
  note      = {Complete pivoting for symmetric indefinite systems. Theoretical ceiling
               for pivot stability — more expensive than BK but establishes correctness
               bounds. Read for the existence theorem and inertia preservation proof.}
}

