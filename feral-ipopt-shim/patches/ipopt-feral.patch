Add feral as a linear_solver=feral option in Ipopt 3.14.

Three changes to src/Algorithm/IpAlgBuilder.cpp:
  1. #include "IpFeralSolverInterface.hpp" at the top.
  2. Register "feral" in the linear_solver option's value list.
  3. Add `else if (linear_solver == "feral")` dispatch branch.

Two changes to src/Makefile.am:
  Compile IpFeralSolverInterface.cpp into libipopt unconditionally.

Two changes to src/Makefile.in (POC: avoids needing COIN-OR BuildTools
m4 macros to re-run autoreconf):
  Add IpFeralSolverInterface.lo to am_libipopt_la_OBJECTS and
  IpFeralSolverInterface.cpp to libipopt_la_SOURCES, mirroring the
  Makefile.am change.

If COIN-OR BuildTools is installed, run `autoreconf -i` to regenerate
Makefile.in cleanly; otherwise the Makefile.in hunks below are
sufficient for the POC build.

--- a/src/Algorithm/IpAlgBuilder.cpp
+++ b/src/Algorithm/IpAlgBuilder.cpp
@@ -72,6 +72,7 @@
 #ifdef IPOPT_HAS_MUMPS
 # include "IpMumpsSolverInterface.hpp"
 #endif
+#include "IpFeralSolverInterface.hpp"

 namespace Ipopt
 {
@@ -200,6 +201,9 @@
       descrs.push_back("use the Mumps package");
    }

+   options.push_back("feral");
+   descrs.push_back("use the feral package (pure-Rust sparse LDLT)");
+
    options.push_back("custom");
    descrs.push_back("use custom linear solver (expert use)");

@@ -513,6 +517,11 @@
    }
 #endif

+   else if( linear_solver == "feral" )
+   {
+      SolverInterface = new FeralSolverInterface();
+      linear_solver = FeralSolverInterface::GetName();
+   }
    else if( linear_solver == "custom" )
    {
       SolverInterface = NULL;
